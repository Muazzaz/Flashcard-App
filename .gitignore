# ============================================
# Monorepo — Root .gitignore
# ============================================

# ---- Node (both packages) ----
node_modules/
npm-debug.*
yarn-debug.*
yarn-error.*

# ---- Environment secrets ----
.env
.env.local
.env*.local
.dev.vars          # Cloudflare Workers local secrets (backend/)

# ---- Expo / React Native (flashcard/) ----
.expo/
dist/
web-build/
expo-env.d.ts
.metro-health-check*
*.tsbuildinfo

# ---- Native build artifacts ----
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# ---- Cloudflare Workers (backend/) ----
backend/.wrangler/
backend/drizzle/
wrangler.output.log

# ---- macOS ----
.DS_Store
*.pem

# ---- Generated native folders (Expo prebuild) ----
/flashcard/ios
/flashcard/android
