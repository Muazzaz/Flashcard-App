{
  "name": "vocab-app",
  "version": "1.0.0",
  "private": true,
  "description": "Agency-First Vocabulary App — monorepo containing the React Native frontend and Cloudflare Workers backend.",
  "workspaces": [
    "flashcard",
    "backend"
  ],
  "scripts": {
    "app": "npm run start --workspace=flashcard",
    "app:android": "npm run android --workspace=flashcard",
    "app:ios": "npm run ios --workspace=flashcard",
    "api": "npm run dev --workspace=backend",
    "api:deploy": "npm run deploy --workspace=backend",
    "db:generate": "npm run db:generate --workspace=backend",
    "db:push": "npm run db:push --workspace=backend"
  }
}
